# IBKR MCP Server — Environment Variable Template
# Copy this file to `.env` and edit values as needed. All variables are optional;
# defaults shown below match `spec.md` §3.1, with the corrected paper-trading port.

# --- IB Gateway / TWS connection -------------------------------------------------

# Host where IB Gateway / TWS is listening.
IB_HOST=127.0.0.1

# Gateway / TWS port. Defaults to 4002 (paper) so it matches IB_PAPER_TRADING=true.
#   IB Gateway live  : 4001
#   IB Gateway paper : 4002   <-- default
#   TWS live         : 7496
#   TWS paper        : 7497
IB_PORT=4002

# TWS client ID. Must be unique per concurrent connection to the same Gateway.
IB_CLIENT_ID=1

# Specific account ID. If omitted, the first managed account is used.
# IB_ACCOUNT=U1234567

# Informational flag — logged on startup so it is visible to operators.
IB_PAPER_TRADING=true

# Required for flex query tools. If omitted, list_flex_queries / get_flex_query
# are not registered.
# IB_FLEX_TOKEN=

# Market data subscription type. One of: LIVE, FROZEN, DELAYED, DELAYED_FROZEN.
IB_MARKET_DATA_TYPE=LIVE

# --- MCP transport ---------------------------------------------------------------

# Transport: stdio or streamable-http
MCP_TRANSPORT=streamable-http

# HTTP bind address (Streamable HTTP mode only). Localhost-only in v0.1.
MCP_HTTP_HOST=127.0.0.1

# HTTP bind port (Streamable HTTP mode only).
MCP_HTTP_PORT=8400

# --- Logging ---------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log output format: json (machine-readable) or console (human-readable)
LOG_FORMAT=json

# When true, every tool invocation is logged with input params, duration, and outcome.
LOG_TOOL_CALLS=false
